  {
    "id": "TC007",
    "title": "Create a new budget with amount, categories, and period",
    "description": "Verifies a user can create a budget and see it listed with alerts enabled.",
    "category": "Budget Planning (Orçamento)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /auth"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" or \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "action",
        "description": "Click on the \"Orçamento\" or \"Budget\" navigation item"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/orcamento\""
      },
      {
        "type": "action",
        "description": "Click the \"Set Budget\" button"
      },
      {
        "type": "action",
        "description": "Type \"1000\" into the budget amount field"
      },
      {
        "type": "action",
        "description": "Select a budget period option (for example \"Monthly\") from the period dropdown"
      },
      {
        "type": "action",
        "description": "Select at least one category in the categories selector"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"1000\" is visible in the budgets list"
      },
      {
        "type": "assertion",
        "description": "Verify text indicating the budget is active or alerts are enabled is visible"
      }
    ]
  },
